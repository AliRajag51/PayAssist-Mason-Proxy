# Copy to .env.local for local dev and fill in your values.
# Deployment values are passed via docker-compose (see docker-compose.yml).

# Public backend base URL (NO /api suffix).
#  - Local dev:   http://localhost:5000
#  - Deployments: leave EMPTY — the browser then calls same-origin /api/*, which
#    the built-in proxy route forwards privately to INTERNAL_API_BASE_URL.
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000

# Stripe PUBLISHABLE key (test mode: pk_test_...). Same Stripe account as the
# backend's secret key. The card option stays hidden in checkout until set.
NEXT_PUBLIC_STRIPE_KEY=

# PayPal client id (public, from developer.paypal.com). The PayPal option stays
# hidden in checkout until set.
NEXT_PUBLIC_PAYPAL_CLIENT_ID=

# Master on/off toggle for the Stripe card option in checkout (default true). Set false to hide Stripe even when a key is configured.
NEXT_PUBLIC_ENABLE_STRIPE=true
# Master on/off toggle for the PayPal option in checkout (default true). Set false to hide PayPal even when a client id is configured.
NEXT_PUBLIC_ENABLE_PAYPAL=true

# Runtime-only (Docker / server). Private-network URL of the backend used by SSR
# and the /api proxy route. Defaults: http://backend:5000 in Docker (see
# Dockerfile), http://localhost:5000 in local dev.
# INTERNAL_API_BASE_URL=http://backend:5000

# Used ONLY by the DB seed scripts (npm run seed / seed:admin), never by the app.
# Pass at runtime; copy from E-comm Backend/.env.
# MONGO_URI=
